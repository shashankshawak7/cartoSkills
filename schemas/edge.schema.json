{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UCCS Edge Schema",
  "description": "Formal schema for a Universal Code Cartography Schema (UCCS) structural relationship.",
  "type": "object",
  "required": ["source", "target", "type"],
  "properties": {
    "source": {
      "type": "string",
      "description": "The URI ID of the source node.",
      "pattern": "^[a-z_]+://.+#.+$"
    },
    "target": {
      "type": "string",
      "description": "The URI ID of the target node.",
      "pattern": "^[a-z_]+://.+#.+$"
    },
    "type": {
      "type": "string",
      "description": "The nature of the structural relationship.",
      "enum": ["CONTAINS", "CALLS", "EXTENDS", "IMPLEMENTS", "USES", "DECORATES", "TRIGGERS", "STYLES", "RENDERS"]
    },
    "properties": {
      "type": "object",
      "properties": {
        "external": { "type": "boolean", "default": false },
        "dynamic": { "type": "boolean", "default": false },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
