{
  "global": {
    "directories": [".git", ".svn", ".hg", ".idea", ".vscode", ".settings", ".devcontainer", ".github", ".mvn", ".gradle"],
    "files": [".gitignore", ".DS_Store", "package-lock.json", "yarn.lock", "poetry.lock", "pom.xml.releaseBackup", "status.json", "graph.json", "project_tree.json", "symbol_table.json", "documentation_status.json"]
  },
  "python": {
    "directories": ["__pycache__", "venv", ".venv", ".tox", ".pytest_cache", ".mypy_cache", "dist", "build", "nosetests"],
    "files": ["*.pyc", "*.pyo", "*.pyd", ".python-version", "pip-log.txt"]
  },
  "nodejs": {
    "directories": ["node_modules", "dist", "build", "out", ".next", ".nuxt", ".cache"],
    "files": ["npm-debug.log", "yarn-debug.log", "yarn-error.log"]
  },
  "java": {
    "directories": ["target", "build", "bin", "out", ".gradle", ".m2"],
    "files": ["*.class", "*.jar", "*.war", "*.ear"]
  },
  "csharp": {
    "directories": ["bin", "obj", ".vs", "TestResults"],
    "files": ["*.exe", "*.dll", "*.pdb", "*.suo"]
  },
  "php": {
    "directories": ["vendor", "_vendor"],
    "files": ["composer.lock"]
  },
  "cpp": {
    "directories": ["build", "bin", "obj", "Debug", "Release"],
    "files": ["*.o", "*.obj", "*.out", "*.app"]
  }
}
