{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UCCS Graph Schema",
  "description": "Formal schema for a complete Universal Code Cartography Schema (UCCS) structural graph.",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "project": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "version": { "type": "string" }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "node.schema.json" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "edge.schema.json" }
    }
  },
  "additionalProperties": false
}
